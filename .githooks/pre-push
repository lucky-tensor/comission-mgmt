#!/bin/bash
set -e

REMOTE="$1"
REMOTE_URL="$2"
echo "=== Pre-push: Running quality gate checks (push to $REMOTE) ==="

echo ""
echo "--- 1/6 Type check ---"
bun run typecheck

echo ""
echo "--- 2/6 Lint check ---"
bun run lint

echo ""
echo "--- 3/6 Format check ---"
bun run format:check

echo ""
echo "--- 4/6 Build verification ---"
bun run build

echo ""
echo "--- 5/6 SQL-injection gate ---"
bun run check:sql-injection

echo ""
echo "--- 6/6 CRM symbol ban ---"
HITS=$(grep -rn --include='*.ts' --include='*.tsx' \
  'smart-crm\|from.*crm\|annotation\|ingestion' \
  apps/ packages/ 2>/dev/null | grep -v node_modules | grep -v '.d.ts' || true)
if [[ -n "$HITS" ]]; then
  echo "ERROR: CRM-specific symbols found in source:"
  echo "$HITS"
  exit 1
fi
echo "OK: no CRM symbols found."

echo ""
echo "=== All quality checks passed ==="
