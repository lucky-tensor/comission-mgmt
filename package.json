{
  "name": "commission-mgmt",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run test:unit",
    "test:unit": "bun --bun vitest run packages/core/tests apps/server/tests/unit",
    "test:db": "bun --bun vitest run packages/db/tests",
    "test:migration": "bun --bun vitest run --config vitest.migration.config.ts",
    "migrate": "bun run packages/db/migrate.ts",
    "typecheck": "bun tsc --noEmit",
    "lint": "bunx eslint .",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "bun-types": "^1.3.14",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jiti": "^2.7.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
