{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["bun-types"],
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "baseUrl": ".",
    "paths": {
      "core": ["packages/core/index.ts"],
      "core/*": ["packages/core/*.ts"],
      "db": ["packages/db/index.ts"],
      "db/*": ["packages/db/*.ts"]
    }
  },
  "exclude": ["node_modules"]
}
