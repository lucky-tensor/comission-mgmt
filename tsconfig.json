{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["bun-types"],
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "baseUrl": ".",
    "paths": {
      "core": ["packages/core/index.ts"],
      "core/*": ["packages/core/*.ts"],
      "db": ["packages/db/index.ts"],
      "db/placements": ["packages/db/src/placements.ts"],
      "db/contributors": ["packages/db/src/contributors.ts"],
      "db/attribution": ["packages/db/src/attribution.ts"],
      "db/plans": ["packages/db/src/plans.ts"],
      "db/commission-records": ["packages/db/src/commission-records.ts"],
      "db/commission-runs": ["packages/db/src/commission-runs.ts"],
      "db/exceptions": ["packages/db/src/exceptions.ts"],
      "db/invoices": ["packages/db/src/invoices.ts"],
      "db/*": ["packages/db/*.ts"]
    }
  },
  "exclude": ["node_modules"]
}
